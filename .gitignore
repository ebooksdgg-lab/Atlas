# Credentials and secrets (NEVER commit)
claves meta/
claves*/
*tokens*.txt
*credentials*.txt
*secrets*.txt

# Environment
.env
.env.local
.env.*.local
!.env.example

# Node
node_modules/
.next/
out/
dist/
build/

# Docker volumes (never commit data)
infra/postgres-data/
infra/redis-data/
infra/evolution/instances/
infra/typebot/uploads/
infra/chatwoot/storage/
infra/chatwoot/public/
infra/backups/

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# Claude Code local settings
.claude/settings.local.json

# IDE
.idea/
.vscode/
*.swp

# Drizzle — commit migrations and meta (journal + snapshots needed for drizzle-kit diff)
# drizzle/ is intentionally tracked
