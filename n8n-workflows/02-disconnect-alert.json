{
  "name": "Atlas — Disconnect Alert",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "atlas-disconnect-alert",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-disconnect",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "atlas-disconnect-alert"
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "check-event",
              "leftValue": "={{ $json.eventType }}",
              "rightValue": "disconnected",
              "operator": { "type": "string", "operation": "equals" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "filter-disconnect",
      "name": "Only disconnected",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 1,
      "position": [460, 300]
    },
    {
      "parameters": {
        "authentication": "oAuth2",
        "select": "channel",
        "channelId": { "value": "SLACK_CHANNEL_ID", "mode": "id" },
        "text": ":red_circle: *Número desconectado*: `{{ $json.phoneNumber }}`\n• Producto: {{ $json.productName ?? $json.productSlug }}\n• Instancia Evolution: {{ $json.evolutionInstanceName ?? '—' }}\n• _{{ $now.format('dd/MM/yyyy HH:mm') }}_\n\n:point_right: <https://atlas.ebooksdgg.lat/number/{{ $json.numberId }}|Ver en Atlas>",
        "otherOptions": {
          "includeLinkToWorkflow": false
        }
      },
      "id": "slack-disconnect",
      "name": "Slack — desconexión",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.2,
      "position": [680, 220],
      "credentials": {
        "slackOAuth2Api": { "id": "REPLACE_SLACK_CRED_ID", "name": "Slack Atlas" }
      }
    },
    {
      "parameters": {
        "resource": "databasePage",
        "operation": "create",
        "databaseId": { "value": "NOTION_DB_ALERTS_ID", "mode": "id" },
        "title": "Desconexión — {{ $json.phoneNumber }}",
        "propertiesUi": {
          "propertyValues": [
            { "key": "Tipo", "type": "select", "selectValue": "disconnected" },
            { "key": "Número", "type": "rich_text", "textContent": "={{ $json.phoneNumber }}" },
            { "key": "Producto", "type": "rich_text", "textContent": "={{ $json.productName ?? $json.productSlug }}" },
            { "key": "Detalle", "type": "rich_text", "textContent": "={{ JSON.stringify($json.data) }}" },
            { "key": "Fecha", "type": "date", "dateValue": "={{ $now.toISO() }}" }
          ]
        }
      },
      "id": "notion-disconnect",
      "name": "Notion — log desconexión",
      "type": "n8n-nodes-base.notion",
      "typeVersion": 2.2,
      "position": [680, 380],
      "credentials": {
        "notionApi": { "id": "REPLACE_NOTION_CRED_ID", "name": "Notion Atlas" }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"ok\": true }"
      },
      "id": "respond-disconnect",
      "name": "Respond",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [900, 300]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [[{ "node": "Only disconnected", "type": "main", "index": 0 }]]
    },
    "Only disconnected": {
      "main": [
        [
          { "node": "Slack — desconexión", "type": "main", "index": 0 },
          { "node": "Notion — log desconexión", "type": "main", "index": 0 }
        ]
      ]
    },
    "Slack — desconexión": {
      "main": [[{ "node": "Respond", "type": "main", "index": 0 }]]
    }
  },
  "active": false,
  "settings": { "executionOrder": "v1" },
  "meta": {
    "templateCredsSetupCompleted": false
  },
  "notes": "Recibe POST desde Atlas /api/webhooks/evolution cuando eventType=disconnected. Completar: SLACK_CHANNEL_ID, URL de Atlas, credenciales Slack y Notion."
}
