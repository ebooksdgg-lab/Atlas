# ─────────────────────────────────────────────────────────────────
# Atlas — Environment Variables
# cp .env.example .env  →  fill every blank value before first run
# ─────────────────────────────────────────────────────────────────

SERVER_DOMAIN=ebooksdgg.lat

# ─── PostgreSQL ──────────────────────────────────────────────────
# openssl rand -hex 32
POSTGRES_PASSWORD=

# ─── Redis ───────────────────────────────────────────────────────
# openssl rand -hex 32
REDIS_PASSWORD=

# ─── Evolution API ───────────────────────────────────────────────
# openssl rand -hex 32
EVOLUTION_AUTH_API_KEY=

# ─── Typebot ─────────────────────────────────────────────────────
# openssl rand -hex 16  (exactly 32 hex chars)
TYPEBOT_ENCRYPTION_SECRET=
# openssl rand -hex 32
TYPEBOT_NEXTAUTH_SECRET=
TYPEBOT_ADMIN_EMAIL=luchoeditor@gmail.com
# Get from Typebot builder UI after first login: Settings → API tokens
TYPEBOT_API_TOKEN=

# ─── Chatwoot ────────────────────────────────────────────────────
# openssl rand -hex 64
CHATWOOT_SECRET_KEY_BASE=
# Get from Chatwoot UI after first login: Settings → Integrations → API Access Token
CHATWOOT_API_TOKEN=
# Chatwoot account ID (defaults to 1 for single-tenant installs)
CHATWOOT_ACCOUNT_ID=1

# ─── Meta App — App 1 (production) ──────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_CONFIG_ID=
# Random string you choose; used to verify Meta webhook calls
META_VERIFY_TOKEN=
META_API_VERSION=v21.0

# ─── Atlas app ───────────────────────────────────────────────────
# openssl rand -hex 32
ATLAS_NEXTAUTH_SECRET=
# openssl rand -hex 32  —  AES-256 key for encrypting Meta app secrets in DB
ATLAS_ENCRYPTION_KEY=
ATLAS_ADMIN_EMAIL_LUCHO=luchoeditor@gmail.com
ATLAS_ADMIN_EMAIL_GABI=

# ─── n8n (existing instance) ─────────────────────────────────────
# No trailing slash
N8N_BASE_URL=https://n8n.ebooksdgg.lat
# n8n API key (Settings → n8n API → Create an API key)
N8N_API_KEY=

# ─── Slack ───────────────────────────────────────────────────────
# Incoming Webhook URL from your Slack App (api.slack.com/apps)
SLACK_WEBHOOK_URL=

# ─── Notion ──────────────────────────────────────────────────────
# Integration token from notion.so/my-integrations
NOTION_API_KEY=
# ID of the Notion database for the audit event log
NOTION_DATABASE_ID=

# ─── SMTP (Chatwoot + Typebot + Atlas daily report) ──────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
